+EncodedImage VisionEncoderGemma4::encode_audio(const ov::Tensor& waveform) {
+    OPENVINO_ASSERT(m_audio_encoder_requests,
+                    "Audio tensor given but openvino_audio_embeddings_model.xml was not found next to the model");
+    const float* src = waveform.data<const float>();
+    const size_t nsamples = waveform.get_size();
+    constexpr size_t SAMPLES_PER_TOKEN = 640;  // 40 ms at 16 kHz
+    const size_t n_tokens = (nsamples + SAMPLES_PER_TOKEN - 1) / SAMPLES_PER_TOKEN;
+    ov::Tensor frames(ov::element::f32, {1, n_tokens, SAMPLES_PER_TOKEN});
+    float* dst = frames.data<float>();
+    std::fill(dst, dst + n_tokens * SAMPLES_PER_TOKEN, 0.0f);
+    std::copy(src, src + nsamples, dst);
+
+    CircularBufferQueueElementGuard<ov::InferRequest> guard(m_audio_encoder_requests.get());
+    ov::InferRequest& req = guard.get();
+    req.set_input_tensor(frames);
+    req.infer();
+    const ov::Tensor& out = req.get_output_tensor();
+    ov::Tensor audio_features(out.get_element_type(), out.get_shape());
+    out.copy_to(audio_features);
+
+    EncodedImage encoded;
+    encoded.resized_source = std::move(audio_features);
+    encoded.is_audio = true;
+    return encoded;
+}
